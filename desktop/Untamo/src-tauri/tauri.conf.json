{
  "productName": "Untamo",
  "version": "0.2.0",
  "identifier": "com.Untamo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "audio/rooster.flac",
      "audio/analog-watch.flac"
    ],
    "targets": "all"
  },
  "app": {
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Untamo",
        "width": 450,
        "height": 790
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "untamo_audio_play",
          "sidecar": true,
          "args": ["--volume", { "validator": "\\S+" }, "--file", { "validator": "\\S+" }]
        },
        {
          "name": "zbarcam",
          "cmd": "zbarcam",
          "args": ["-1"]
        }
      ]
    },
    "http": {
      "scope": ["https://**", "http://**"]
    },
    "fs": {
      "scope": {
        "allow": ["$APPLOCALDATA/**"]
      }
    }
  }
}
